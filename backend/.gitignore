region_id_based_outputs*/
region_id_based_animation_outputs*/
animation_output/
animation_outputs/
add_animation_output/
add_animation_outputs/

# TTS 出力
tts/
tts_output/
tts_outputs/
audio/

# ffmpeg 連結後の動画
lectures/
slides_output/
final_lecture/
lecture_outputs/output_final/
lecture_outputs/final/
output_final/

# AUTO_LECTURE 全体の出力ルート
lecture_outputs/

# ALL_PAGE_SCAN（スキャン画像など）
lecture_outputs/all_page_scan_outputs/
all_page_scan_output/
all_page_scan_outputs/

