# backend ignore rules
# ================================
# Python
# ================================
__pycache__/
*.pyc
*.pyo
*.pyd

# 仮想環境（あなたは .venv を使用）
.venv/
venv/
env/
.venv_*/

# ================================
# VSCode
# ================================
.vscode/

# ================================
# API Keys / Secrets（絶対 Git に入れない）
# ================================
apikey.txt
*.env
.env
*.secret
secret.txt

# ================================
# teachingmaterial
# ================================
teachingmaterial/img/
teachingmaterial/pdf/
outputs/

# =========================
# AUTO_LECTURE: 実験生成物
# =========================
/experiments/runs/**

# runs フォルダ自体は残したい場合（空フォルダ対策）
!/experiments/runs/.gitkeep

# ================================
# GPTに渡す用
# ================================
collected_source

